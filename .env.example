# Token Bearer para acceder al proxy. Generar uno largo y secreto, ej.:
# openssl rand -hex 32
OLLAMA_PROXY_API_KEY=pon_aqui_un_token_muy_largo_y_secreto

# Opcional: URL de Ollama (por defecto host.docker.internal:11434)
# OLLAMA_TARGET=http://host.docker.internal:11434

# Opcional: puerto del proxy (por defecto 8080)
# PORT=8080
